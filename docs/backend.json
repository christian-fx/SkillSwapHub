{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the system.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID from Firebase Auth."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "phone": {
            "type": "string",
            "description": "The user's phone number."
        },
        "avatarUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL of the user's avatar image."
        }
      },
      "required": ["uid", "name"]
    }
  },
  "auth": {
    "providers": ["email", "google", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores public information for each user."
    }
  }
}
